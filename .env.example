# Telegram Bot
TELEGRAM_TOKEN=replace_me
ADMIN_USERNAMES=@alice,@bob

# Bot Language — "eng" (English, default) or "ru" (Russian)
BOT_LANGUAGE=eng

# Linear API
LINEAR_API_KEY=replace_me

# Database (default: cibot.db)
DB_PATH=./cibot.db

# Message log CSV path (default: messages.csv)
MESSAGES_CSV=./messages.csv

# Technical threads — /thread and /close commands (optional)
# TECH_GROUP_ID=-1001234567890

# DNS management via ps.kz (experimental, optional)
# DNS_EMAIL=you@example.com
# DNS_PASSWORD=your_password
